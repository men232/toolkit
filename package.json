{
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "clean": "pnpm clean:dist && pnpm clean:node_modules",
    "clean:dist": "rimraf --glob packages/*/dist temp .eslintcache",
    "clean:node_modules": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "lint": "eslint --cache .",
    "build": "pnpm run -r build",
    "check-types": "pnpm run -r check-types",
    "test": "pnpm run -r test",
    "test:watch": "pnpm run -r test:watch",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "preinstall": "npx only-allow pnpm",
    "docs:generate": "node ./scripts/generate-docs.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare-publish": "node ./scripts/update-version.mjs && pnpm run build && SKIP_PERFORMANCE_TEST=true pnpm run test",
    "publish-all": "pnpm publish --filter \"@andrew_l/*\" --access public"
  },
  "engines": {
    "node": ">=18.12.0",
    "pnpm": "11.11.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.17.1",
    "fs-extra": "^11.3.6",
    "glob": "^11.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0",
    "vitepress": "^1.6.4"
  }
}
