#!/bin/bash

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_FILE="$ROOT_DIR/../dist/vrun.mjs"
TSX_BIN="$ROOT_DIR/../node_modules/.bin/tsx"
DEV_MODE=0
WATCH_MODE=0
ARGS=()

for arg in "$@"; do
  if [ "$arg" == "--dev" ]; then
    DEV_MODE=1
    ARGS+=("$arg")
  elif [ "$arg" == "--watch" ]; then
    WATCH_MODE=1
  else
    ARGS+=("$arg")
  fi
done

if [ $DEV_MODE -eq 1 ]; then
  if [ $WATCH_MODE -eq 1 ]; then
    VRUN=true VRUN_TS_MODE=tsx VRUN_WATCH=true "$TSX_BIN" watch $SCRIPT_FILE "${ARGS[@]}"
  else
    VRUN=true VRUN_TS_MODE=tsx-register node $SCRIPT_FILE "$@"
  fi
else
  VRUN=true node $SCRIPT_FILE "$@"
fi
