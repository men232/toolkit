{
  "name": "@andrew_l/app",
  "version": "0.3.6",
  "description": "Application runner.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "app",
    "runner"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/men232/toolkit.git",
    "directory": "packages/app"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "unbuild",
    "prepack": "unbuild",
    "test": "vitest run --typecheck",
    "test:watch": "vitest watch --typecheck"
  },
  "bin": {
    "vrun": "bin/vrun"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@andrew_l/graceful": "workspace:*",
    "@andrew_l/toolkit": "workspace:*",
    "commander": "^13.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2"
  },
  "peerDependencies": {
    "tsx": "^4.22.4"
  }
}
