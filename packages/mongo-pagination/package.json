{
  "name": "@andrew_l/mongo-pagination",
  "version": "0.4.1",
  "description": "Manages pagination without relying on traditional offsets.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "mongo",
    "mongodb",
    "mongoose",
    "pagination",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/men232/toolkit.git",
    "directory": "packages/mongo-pagination"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "obuild",
    "prepack": "obuild",
    "test": "vitest run --typecheck",
    "test:watch": "vitest watch --typecheck"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./mongoose-7": {
      "import": "./dist/mongoose-7.mjs",
      "require": "./dist/mongoose-7.mjs",
      "types": "./dist/mongoose-7.d.mts"
    },
    "./mongoose-8": {
      "import": "./dist/mongoose-8.mjs",
      "require": "./dist/mongoose-8.mjs",
      "types": "./dist/mongoose-8.d.mts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "catalog:",
    "mongoose-v7": "npm:mongoose@7.6.3",
    "mongoose-v8": "npm:mongoose@8.8.0",
    "obuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@andrew_l/tl-pack": "workspace:*",
    "@andrew_l/toolkit": "workspace:*",
    "debug": "^4.3.7",
    "kareem": "^2.6.3"
  },
  "peerDependencies": {
    "mongodb": "^5 || ^6",
    "mongoose": "^7 || ^8"
  }
}
